{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(sed:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(echo:*)",
      "Bash(pwd)",
      "Bash(dir)",
      "Bash(vercel:*)",
      "Bash(powershell.exe:*)",
      "Bash(powershell:*)",
      "Bash(taskkill:*)",
      "Bash(netstat:*)",
      "Agent",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools:*",
      "mcp__plugin_playwright_playwright:*",
      "mcp__plugin_prisma_Prisma-Local:*",
      "mcp__plugin_vercel_vercel:*",
      "mcp__plugin_claude-mem_mcp-search:*"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)"
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "sentry@claude-plugins-official": true,
    "coderabbit@claude-plugins-official": true,
    "prisma@claude-plugins-official": true
  }
}
