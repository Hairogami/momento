generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH (NextAuth compatible) ───────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  image           String?
  emailVerified   DateTime?
  passwordHash    String?
  googleId        String?   @unique
  role            String    @default("client") // client | vendor | admin
  firstName       String?
  lastName        String?
  phone           String?
  location        String?
  companyName     String?
  vendorCategory  String?
  vendorSlug      String?
  username        String?
  completedEvents Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  workspace           Workspace?
  vendor              Vendor?
  vendorProfile       VendorProfile?
  planners            Planner[]
  emailVerifications  EmailVerification[]
  clientConversations Conversation[]        @relation("ClientConversations")
  sentMessages        Message[]             @relation("SentMessages")
  reviews             Review[]
  vendorClaimRequests VendorClaimRequest[]
  favorites           Favorite[]
  notifications       Notification[]
  settings            UserSettings?
}

model UserSettings {
  id                String     @id @default(cuid())
  userId            String     @unique
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Notifications (JSON pour rester flexible côté front)
  notifEmail        Json       @default("{\"messages\":true,\"contact\":true,\"reminders\":true,\"promo\":false}")
  notifPush         Json       @default("{\"messages\":true,\"contact\":true,\"reminders\":false,\"promo\":false}")

  // Apparence
  theme             String     @default("auto")    // light | dark | auto
  palette           String     @default("default")
  language          String     @default("fr")      // fr | en | ar

  // Sécurité
  twoFactorEnabled  Boolean    @default(false)

  // Vendor-only
  isOnVacation      Boolean    @default(false)
  vacationMessage   String?
  serviceCities     String[]   @default([])
  unavailableDates  DateTime[] @default([])

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model EmailVerification {
  id        String    @id @default(cuid())
  token     String    @unique
  type      String    @default("email_verification")
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

// ─── WORKSPACE CLIENT (Notion-style) ─────────────────────────────────────────

model Workspace {
  id         String    @id @default(cuid())
  userId     String    @unique
  eventName  String    @default("Mon événement")
  eventDate  DateTime?
  location   String?
  budget     Float?
  guestCount        Int?
  neededCategories  String    @default("")
  createdAt         DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]
  budgetItems BudgetItem[]
  guests      Guest[]
  bookings    Booking[]
}

model Task {
  id          String    @id @default(cuid())
  workspaceId String
  plannerId   String?
  title       String
  description String?
  dueDate     DateTime?
  completed   Boolean   @default(false)
  category    String?
  aiGenerated Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  planner   Planner?  @relation(fields: [plannerId], references: [id], onDelete: SetNull)
}

model BudgetItem {
  id          String   @id @default(cuid())
  workspaceId String
  category    String
  label       String
  estimated   Float
  actual      Float?
  paid        Boolean  @default(false)
  vendorId    String?
  plannerId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  vendor    Vendor?   @relation(fields: [vendorId], references: [id])
  planner   Planner?  @relation(fields: [plannerId], references: [id], onDelete: SetNull)
}

model Guest {
  id          String   @id @default(cuid())
  workspaceId String
  plannerId   String?
  name        String
  email       String?
  phone       String?
  rsvp        String   @default("pending") // yes | no | pending
  plusOne     Boolean  @default(false)
  tableNumber Int?
  notes       String?
  city        String?
  inviteSent  Boolean  @default(false)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  planner   Planner?  @relation(fields: [plannerId], references: [id], onDelete: SetNull)
}

// ─── ANNUAIRE PRESTATAIRES ────────────────────────────────────────────────────

model Vendor {
  id          String   @id @default(cuid())
  userId      String?  @unique
  name        String
  slug        String   @unique
  category    String
  description String?
  city        String?
  region      String?
  address     String?
  lat         Float?
  lng         Float?
  priceMin    Float?
  priceMax    Float?
  priceRange  String? // budget | mid | premium
  phone       String?
  email       String?
  website     String?
  instagram   String?
  facebook    String?
  verified    Boolean  @default(false)
  featured    Boolean  @default(false)
  rating      Float?
  reviewCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User?               @relation(fields: [userId], references: [id])
  verification VendorVerification?
  packages     Package[]
  bookings     Booking[]
  budgetItems  BudgetItem[]
  media        VendorMedia[]
  stepVendors  StepVendor[]
  reviews      Review[]
  plannerEvents PlannerEvent[]
  favorites    Favorite[]
}

model VendorVerification {
  id              String    @id @default(cuid())
  vendorId        String    @unique
  instagramUrl    String?
  instagramHandle String?
  facebookUrl     String?
  facebookHandle  String?
  instagramOk     Boolean   @default(false)
  facebookOk      Boolean   @default(false)
  followersCount  Int?
  lastChecked     DateTime?
  verifiedAt      DateTime?
  notes           String?

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model VendorMedia {
  id        String   @id @default(cuid())
  vendorId  String
  url       String
  type      String   @default("image") // image | video
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

// ─── PROFIL PRESTATAIRE (auto-géré) ──────────────────────────────────────────

model VendorProfile {
  id          String   @id @default(cuid())
  slug        String   @unique
  userId      String   @unique
  description String?
  phone       String?
  email       String?
  website     String?
  instagram   String?
  facebook    String?
  whatsapp    String?
  priceFrom   Int?
  priceTo     Int?
  address     String?
  photos      String[]
  claimed     Boolean  @default(true)
  verified    Boolean  @default(false)
  plan        String   @default("free") // free | pro
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── PACKS & RÉSERVATIONS ─────────────────────────────────────────────────────

model Package {
  id          String   @id @default(cuid())
  vendorId    String
  name        String
  description String?
  price       Float
  duration    String?
  includes    String?
  maxGuests   Int?
  available   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendor   Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  bookings Booking[]
}

model Booking {
  id          String    @id @default(cuid())
  workspaceId String
  plannerId   String?
  vendorId    String
  packageId   String?
  status      String    @default("inquiry") // inquiry | confirmed | cancelled
  eventDate   DateTime?
  totalPrice  Float?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  planner   Planner?  @relation(fields: [plannerId], references: [id], onDelete: SetNull)
  vendor    Vendor    @relation(fields: [vendorId], references: [id])
  package   Package?  @relation(fields: [packageId], references: [id])
}

model ContactRequest {
  id          String   @id @default(cuid())
  vendorSlug  String
  clientName  String
  clientEmail String
  clientPhone String?
  eventType   String?
  eventDate   String?
  message     String
  status      String   @default("pending")
  createdAt   DateTime @default(now())
}

// ─── PLANNER (organisation étape par étape) ───────────────────────────────────

model Planner {
  id          String         @id @default(cuid())
  title       String
  coupleNames String
  weddingDate DateTime?
  budget      Float?
  guestCount  Int?
  location    String?
  coverColor  String         @default("#f9a8d4")
  userId      String?
  user        User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  steps       Step[]
  events      PlannerEvent[]
  budgetItems BudgetItem[]
  tasks       Task[]
  guests      Guest[]
  bookings    Booking[]
  conversations Conversation[]
  favorites     Favorite[]
  notifications Notification[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Step {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      String       @default("todo") // todo | in_progress | done
  category    String       @default("general") // venue | catering | flowers | music | photo | dress | other
  dueDate     DateTime?
  order       Int          @default(0)
  plannerId   String
  planner     Planner      @relation(fields: [plannerId], references: [id], onDelete: Cascade)
  vendors     StepVendor[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model StepVendor {
  id        String  @id @default(cuid())
  stepId    String
  vendorId  String
  notes     String?
  confirmed Boolean @default(false)

  step   Step   @relation(fields: [stepId], references: [id], onDelete: Cascade)
  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model PlannerEvent {
  id        String    @id @default(cuid())
  title     String
  date      DateTime
  endDate   DateTime?
  type      String    @default("task")        // task | appointment | deadline
  status    String    @default("pending")     // pending | confirmed | cancelled
  color     String    @default("#f9a8d4")
  vendorId  String?
  plannerId String
  planner   Planner   @relation(fields: [plannerId], references: [id], onDelete: Cascade)
  vendor    Vendor?   @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  createdAt DateTime  @default(now())
}

// ─── LISTE D'ATTENTE ─────────────────────────────────────────────────────────

model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

// ─── MESSAGERIE ───────────────────────────────────────────────────────────────

model Conversation {
  id         String    @id @default(cuid())
  clientId   String
  vendorSlug String
  plannerId  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  client     User      @relation("ClientConversations", fields: [clientId], references: [id], onDelete: Cascade)
  planner    Planner?  @relation(fields: [plannerId], references: [id], onDelete: SetNull)
  messages   Message[]

  @@unique([clientId, vendorSlug])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
}

model Review {
  id         String   @id @default(cuid())
  vendorId   String
  authorId   String
  rating     Int      // 1–5
  comment    String?  @db.Text
  eventType  String?  // "Mariage", "Fiançailles", etc.
  createdAt  DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([authorId, vendorId])
}

// CR-003: Vendor claim requests go through admin review before role elevation
model VendorClaimRequest {
  id          String   @id @default(cuid())
  userId      String
  slug        String
  status      String   @default("pending") // pending | approved | rejected
  submittedAt DateTime @default(now())
  reviewedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── FAVORIS ─────────────────────────────────────────────────────────────────

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  vendorId  String
  plannerId String?  // associé à un événement spécifique si présent
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendor  Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  planner Planner? @relation(fields: [plannerId], references: [id], onDelete: SetNull)

  @@unique([userId, vendorId, plannerId])
}

// ─── NOTIFICATIONS ───────────────────────────────────────────────────────────

model Notification {
  id           String    @id @default(cuid())
  userId       String
  type         String    // reminder_favorite | booking_confirmed | booking_request | event_approaching | message_new | review_request
  title        String
  body         String?
  read         Boolean   @default(false)
  plannerId    String?   // événement concerné (null = global)
  vendorId     String?   // prestataire concerné si applicable
  scheduledFor DateTime? // pour les rappels différés
  createdAt    DateTime  @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planner Planner? @relation(fields: [plannerId], references: [id], onDelete: SetNull)
}
