    "@prisma/client": "^7.7.0",
    "@sentry/nextjs": "^10.50.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/blob": "^2.3.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.7.0",
    "next": "^16.2.4",
    "next-auth": "5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "prisma": "^7.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
