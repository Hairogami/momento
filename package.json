{
  "name": "momento",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "DATABASE_URL=$DIRECT_URL prisma db push --accept-data-loss && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:prod": "BASE_URL=https://momentoevents.app playwright test",
    "analyze": "ANALYZE=true npx next build --webpack"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.85.0",
    "@auth/prisma-adapter": "^2.11.1",
